# === AI provayder (bittasini tanlang, ustuvorlik yuqoridan pastga) ===

# 1) GEMINI (Google)
GEMINI_API_KEY=

# 2) GITHUB MODELS — GitHub token (models:read ruxsati bilan)
#    Modellar: https://github.com/marketplace?type=models
#    MODEL format: publisher/model  (masalan openai/gpt-4o-mini)
GITHUB_TOKEN=

# 3) OpenAI yoki mos provayder
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Model nomi. Bo'sh qoldirsangiz provayderga mos standart tanlanadi:
#   Gemini: gemini-2.0-flash | GitHub: openai/gpt-4o-mini | OpenAI: gpt-4o-mini
MODEL=

# Server porti
PORT=8787

# Frontend manzili (CORS). Prod uchun aniq domen kiriting, dev uchun *
ALLOWED_ORIGIN=*

# (ixtiyoriy) Telegram initData tekshiruvi uchun bot tokeni
# BOT_TOKEN=123456:ABC...

# Admin panel paroli (/behruz620 sahifasi uchun)
ADMIN_KEY=change-this-secret

# Telegram kanalni "baza" sifatida ishlatish (ixtiyoriy, lekin tavsiya)
# Bot shu kanalda ADMIN bo'lishi kerak (Post, Edit, Pin ruxsatlari bilan)
BOT_TOKEN=123456:ABC...
DB_CHANNEL_ID=-1004294226425
