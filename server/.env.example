# === AI provayder (bittasini tanlang) ===

# 1) GEMINI (Google) — kalit berilsa avtomatik ishlatiladi
GEMINI_API_KEY=

# 2) OpenAI yoki mos provayder (Gemini kaliti yo'q bo'lsa)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Model nomi (Gemini: gemini-2.0-flash | OpenAI: gpt-4o-mini)
# Bo'sh qoldirsangiz provayderga mos standart tanlanadi
MODEL=

# Server porti
PORT=8787

# Frontend manzili (CORS). Prod uchun aniq domen kiriting, dev uchun *
ALLOWED_ORIGIN=*

# (ixtiyoriy) Telegram initData tekshiruvi uchun bot tokeni
# BOT_TOKEN=123456:ABC...

# Admin panel paroli (/behruz620 sahifasi uchun)
ADMIN_KEY=change-this-secret

# Telegram kanalni "baza" sifatida ishlatish (ixtiyoriy, lekin tavsiya)
# Bot shu kanalda ADMIN bo'lishi kerak (Post, Edit, Pin ruxsatlari bilan)
BOT_TOKEN=123456:ABC...
DB_CHANNEL_ID=-1004294226425
